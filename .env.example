# KAIROS DApp 环境变量示例
# 复制此文件为 .env 并填写实际值

# ===================
# 前端配置
# ===================
EXPO_PUBLIC_BACKEND_BASE_URL=http://localhost:9091

# ===================
# 后端配置
# ===================
NODE_ENV=production
PORT=9091

# ===================
# 数据库配置（可选）
# ===================
# DATABASE_URL=postgresql://user:password@localhost:5432/kairos

# ===================
# 安全配置
# ===================
# JWT_SECRET=your-secret-key-here
# API_KEY=your-api-key-here
